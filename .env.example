# Google Gemini
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Qdrant Cloud
QDRANT_URL=https://your-cluster.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# Multi-collection names
COLLECTION_SOPS=docs_sops
COLLECTION_DEVIATIONS=docs_deviations
COLLECTION_CAPAS=docs_capas
COLLECTION_DECISIONS=docs_decisions
COLLECTION_AUDITS=docs_audits

# PostgreSQL
POSTGRES_USER=raguser
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=ragdb
POSTGRES_HOST=db
POSTGRES_PORT=5432

# JWT
JWT_SECRET_KEY=replace_with_256bit_secret
JWT_REFRESH_SECRET_KEY=replace_with_256bit_refresh_secret

# Webhook
WEBHOOK_SECRET=replace_with_webhook_secret

# HuggingFace model cache
HF_HOME=/app/models
TRANSFORMERS_CACHE=/app/models
